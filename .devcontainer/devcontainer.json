{
  "name": "git-expunge",
  "build": {
    "dockerfile": "../Containerfile.dev"
  },
  "features": {
    "ghcr.io/devcontainers/features/go:1": {
      "version": "1.25"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "ms-vscode.makefile-tools"
      ],
      "settings": {
        "go.useLanguageServer": true,
        "go.lintTool": "golangci-lint",
        "go.lintFlags": ["--fast"]
      }
    }
  },
  "postCreateCommand": "go mod download",
  "remoteUser": "vscode"
}
